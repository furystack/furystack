{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "jsx": "react",
    "jsxFactory": "createComponent",
    "jsxFragmentFactory": "createComponent",
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022", "DOM", "ESNext"],
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src", "src/**/*.json"],
  "references": [
    {
      "path": "../cache"
    },
    {
      "path": "../core"
    },
    {
      "path": "../i18n"
    },
    {
      "path": "../inject"
    },
    {
      "path": "../logging"
    },
    {
      "path": "../repository"
    },
    {
      "path": "../shades"
    },
    {
      "path": "../shades-common-components"
    },
    {
      "path": "../shades-i18n"
    },
    {
      "path": "../shades-lottie"
    },
    {
      "path": "../shades-mfe"
    },
    {
      "path": "../shades-nipple"
    },
    {
      "path": "../utils"
    }
  ]
}
